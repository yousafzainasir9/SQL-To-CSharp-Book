}

.code-block.csharp code,
.code-block.csharp-method code,
.code-block.csharp-query code {
  color: var(--ink);
}

/* SINGLE CODE BLOCK */
.code-single {
  margin-bottom: 28px;
}

.code-single .code-block {
  max-width: 100%;
}

/* KEY INSIGHT CALLOUT */
.key-insight {
  border-left: 4px solid var(--acc);
